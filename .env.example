# Standalone attack map config. Copy to .env, fill, then:
#   env $(grep -v '^#' .env | xargs) python3 app.py
# NOTE: no inline comments below — the loader splits on whitespace, so keep
# every comment on its own '#' line.

# server
HOST=0.0.0.0
PORT=8100

# sensor "home" the arcs terminate at (cosmetic anchor, not a real victim)
HOME_LAT=52.37
HOME_LON=4.90

# GeoIP: path to a MaxMind GeoLite2-City .mmdb for real geolocation.
# Without it: country-centroid where a feed gives country, else synthetic scatter.
# Free key: https://www.maxmind.com/en/geolite2/signup
GEOIP_MMDB=/home/user/socmap/GeoLite2-City.mmdb

# abuse.ch ThreatFox free Auth-Key (https://auth.abuse.ch/). Blank = skip ThreatFox.
# Feodo / URLhaus / blocklist.de / CINS / DShield need NO key.
THREATFOX_KEY=

# DShield ToS: a contact email must ride in the HTTP User-Agent.
CONTACT_EMAIL=admin@example.com

# animation / load tuning
# EMIT_RATE  arcs streamed per second (smooths feed bursts)
# FIRST_BURST arcs on a feed's first poll (rest seed dedup silently)
# RING       history kept for a new tab's initial paint
# DNS_CAP    urlhaus hostname->IP lookups per poll cycle
# FEED_TIMEOUT per-feed HTTP timeout seconds
EMIT_RATE=6
FIRST_BURST=40
RING=400
DNS_CAP=25
FEED_TIMEOUT=25
