<?xml version="1.0" encoding="utf-8"?>
<!-- Simple vector launcher: dark globe with a red attack arc. Works as an app
     icon on API 24+ (no raster densities needed). -->
<vector xmlns:android="http://schemas.android.com/apk/res/android"
    android:width="108dp"
    android:height="108dp"
    android:viewportWidth="108"
    android:viewportHeight="108">
    <path
        android:fillColor="#05080F"
        android:pathData="M0,0h108v108h-108z" />
    <path
        android:fillColor="#1C2A40"
        android:pathData="M54,22 m-28,0 a28,28 0 1,0 56,0 a28,28 0 1,0 -56,0z"
        android:fillAlpha="0.0" />
    <!-- globe -->
    <path
        android:strokeColor="#46648C"
        android:strokeWidth="2"
        android:fillColor="#13233A"
        android:pathData="M54,26 m-26,0 a26,26 0 1,0 52,0 a26,26 0 1,0 -52,0z" />
    <path
        android:strokeColor="#46648C"
        android:strokeWidth="1.2"
        android:pathData="M28,54 H80 M54,28 V80 M36,36 Q54,46 72,36 M36,72 Q54,62 72,72" />
    <!-- attack arc -->
    <path
        android:strokeColor="#F85149"
        android:strokeWidth="3"
        android:strokeLineCap="round"
        android:pathData="M34,72 Q54,20 76,46" />
    <path
        android:fillColor="#F85149"
        android:pathData="M76,46 m-4,0 a4,4 0 1,0 8,0 a4,4 0 1,0 -8,0z" />
    <path
        android:fillColor="#FFD166"
        android:pathData="M34,72 m-3,0 a3,3 0 1,0 6,0 a3,3 0 1,0 -6,0z" />
